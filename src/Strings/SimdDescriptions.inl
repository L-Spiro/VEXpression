VE_STR1(Desc_mm_bcstnebf16_ps, "Convert scalar BF16 (16-bit) floating-point element stored at memory locations starting at location __A\n to a single-precision (32-bit) floating-point, broadcast it to packed \nsingle-precision (32-bit) floating-point elements, and store the results\n in dst.\n\nb := Convert_BF16_To_FP32(MEM[__A+15:__A])\nFOR j := 0 to 3\n\tm := j*32\n\tdst[m+31:m] := b\nENDFOR\ndst[MAX:128] := 0")
