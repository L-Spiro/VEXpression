VE_STR1(Desc_mm256_dp_ps, "Conditionally multiply the packed single-precision (32-bit) floating-point elements in a and b using the high 4 bits in imm8, sum the four products, and conditionally store the sum in dst using the low 4 bits of imm8.\n\nDEFINE DP(a[127:0], b[127:0], imm8[7:0]) {\n\tFOR j := 0 to 3\n\t\ti := j*32\n\t\tIF imm8[(4+j)%8]\n\t\t\ttemp[i+31:i] := a[i+31:i] * b[i+31:i]\n\t\tELSE\n\t\t\ttemp[i+31:i] := FP32(0.0)\n\t\tFI\n\tENDFOR\n\t\n\tsum[31:0] := (temp[127:96] + temp[95:64]) + (temp[63:32] + temp[31:0])\n\t\n\tFOR j := 0 to 3\n\t\ti := j*32\n\t\tIF imm8[j%8]\n\t\t\ttmpdst[i+31:i] := sum[31:0]\n\t\tELSE\n\t\t\ttmpdst[i+31:i] := FP32(0.0)\n\t\tFI\n\tENDFOR\n\tRETURN tmpdst[127:0]\n}\ndst[127:0] := DP(a[127:0], b[127:0], imm8[7:0])\ndst[255:128] := DP(a[255:128], b[255:128], imm8[7:0])\ndst[MAX:256] := 0")
VE_STR1(Desc_mm_dpbssd_epi32, "Multiply groups of 4 adjacent pairs of signed 8-bit integers in __A with corresponding signed 8-bit integers in __B, producing 4 intermediate signed 16-bit results. Sum these 4 results with the corresponding 32-bit integer in __W, and store the packed 32-bit results in dst.\n\nFOR j := 0 to 3\n\ttmp1.word := SignExtend16(__A.byte[4*j]) * SignExtend16(__B.byte[4*j])\n\ttmp2.word := SignExtend16(__A.byte[4*j+1]) * SignExtend16(__B.byte[4*j+1])\n\ttmp3.word := SignExtend16(__A.byte[4*j+2]) * SignExtend16(__B.byte[4*j+2])\n\ttmp4.word := SignExtend16(__A.byte[4*j+3]) * SignExtend16(__B.byte[4*j+3])\n\tdst.dword[j] := __W.dword[j] + tmp1 + tmp2 + tmp3 + tmp4\nENDFOR\ndst[MAX:128] := 0")
