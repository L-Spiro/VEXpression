// SSE_ALL
// =========================================================================
VE_STR1(Desc_mm_abs_epi16, "Compute the absolute value of packed signed 16-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tdst[i+15:i] := ABS(a[i+15:i])\nENDFOR")
VE_STR1(Desc_mm_abs_epi32, "Compute the absolute value of packed signed 32-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := ABS(a[i+31:i])\nENDFOR")
VE_STR1(Desc_mm_abs_epi8, "Compute the absolute value of packed signed 8-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tdst[i+7:i] := ABS(a[i+7:i])\nENDFOR")
VE_STR1(Desc_mm_abs_pi16, "Compute the absolute value of packed signed 16-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 3\n\ti := j*16\n\tdst[i+15:i] := ABS(Int(a[i+15:i]))\nENDFOR")
VE_STR1(Desc_mm_abs_pi32, "Compute the absolute value of packed signed 32-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 1\n\ti := j*32\n\tdst[i+31:i] := ABS(a[i+31:i])\nENDFOR")
VE_STR1(Desc_mm_abs_pi8, "Compute the absolute value of packed signed 8-bit integers in a, and store the unsigned results in dst.\n\nFOR j := 0 to 7\n\ti := j*8\n\tdst[i+7:i] := ABS(Int(a[i+7:i]))\nENDFOR")
VE_STR1(Desc_mm_add_epi16, "Add packed 16-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tdst[i+15:i] := a[i+15:i] + b[i+15:i]\nENDFOR")
VE_STR1(Desc_mm_add_epi32, "Add packed 32-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := a[i+31:i] + b[i+31:i]\nENDFOR")
VE_STR1(Desc_mm_add_epi64, "Add packed 64-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tdst[i+63:i] := a[i+63:i] + b[i+63:i]\nENDFOR")
VE_STR1(Desc_mm_add_epi8, "Add packed 8-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tdst[i+7:i] := a[i+7:i] + b[i+7:i]\nENDFOR")
VE_STR1(Desc_mm_add_pd, "Add packed double-precision (64-bit) floating-point elements in a and b, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tdst[i+63:i] := a[i+63:i] + b[i+63:i]\nENDFOR")
VE_STR1(Desc_mm_add_ps, "Add packed single-precision (32-bit) floating-point elements in a and b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := a[i+31:i] + b[i+31:i]\nENDFOR")
VE_STR1(Desc_mm_add_sd, "Add the lower double-precision (64-bit) floating-point element in a and b, store the result in the lower element of dst, and copy the upper element from a to the upper element of dst.\n\ndst[63:0] := a[63:0] + b[63:0]\ndst[127:64] := a[127:64]")
VE_STR1(Desc_mm_add_si64, "Add 64-bit integers a and b, and store the result in dst.\n\ndst[63:0] := a[63:0] + b[63:0]")
VE_STR1(Desc_mm_add_ss, "Add the lower single-precision (32-bit) floating-point element in a and b, store the result in the lower element of dst, and copy the upper 3 packed elements from a to the upper elements of dst.\n\ndst[31:0] := a[31:0] + b[31:0]\ndst[127:32] := a[127:32]")
VE_STR1(Desc_mm_adds_epi16, "Add packed signed 16-bit integers in a and b using saturation, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tdst[i+15:i] := Saturate16( a[i+15:i] + b[i+15:i] )\nENDFOR")
VE_STR1(Desc_mm_adds_epi8, "Add packed signed 8-bit integers in a and b using saturation, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tdst[i+7:i] := Saturate8( a[i+7:i] + b[i+7:i] )\nENDFOR")
VE_STR1(Desc_mm_adds_epu16, "Add packed unsigned 16-bit integers in a and b using saturation, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tdst[i+15:i] := SaturateU16( a[i+15:i] + b[i+15:i] )\nENDFOR")
VE_STR1(Desc_mm_adds_epu8, "Add packed unsigned 8-bit integers in a and b using saturation, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tdst[i+7:i] := SaturateU8( a[i+7:i] + b[i+7:i] )\nENDFOR")
VE_STR1(Desc_mm_addsub_pd, "Alternatively add and subtract packed double-precision (64-bit) floating-point elements in a to/from packed elements in b, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tIF ((j & 1) == 0)\n\t\tdst[i+63:i] := a[i+63:i] - b[i+63:i]\n\tELSE\n\t\tdst[i+63:i] := a[i+63:i] + b[i+63:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_addsub_ps, "Alternatively add and subtract packed single-precision (32-bit) floating-point elements in a to/from packed elements in b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tIF ((j & 1) == 0)\n\t\tdst[i+31:i] := a[i+31:i] - b[i+31:i]\n\tELSE\n\t\tdst[i+31:i] := a[i+31:i] + b[i+31:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_alignr_epi8, "Concatenate 16-byte blocks in a and b into a 32-byte temporary result, shift the result right by imm8 bytes, and store the low 16 bytes in dst.\n\ntmp[255:0] := ((a[127:0] << 128)[255:0] OR b[127:0]) >> (imm8*8)\ndst[127:0] := tmp[127:0]")
VE_STR1(Desc_mm_alignr_pi8, "Concatenate 8-byte blocks in a and b into a 16-byte temporary result, shift the result right by imm8 bytes, and store the low 16 bytes in dst.\n\ntmp[127:0] := ((a[63:0] << 64)[127:0] OR b[63:0]) >> (imm8*8)\ndst[63:0] := tmp[63:0]")
VE_STR1(Desc_mm_and_pd, "Compute the bitwise AND of packed double-precision (64-bit) floating-point elements in a and b, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tdst[i+63:i] := (a[i+63:i] AND b[i+63:i])\nENDFOR")
VE_STR1(Desc_mm_and_ps, "Compute the bitwise AND of packed single-precision (32-bit) floating-point elements in a and b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := (a[i+31:i] AND b[i+31:i])\nENDFOR")
VE_STR1(Desc_mm_and_si128, "Compute the bitwise AND of 128 bits (representing integer data) in a and b, and store the result in dst.\n\ndst[127:0] := (a[127:0] AND b[127:0])")
VE_STR1(Desc_mm_andnot_pd, "Compute the bitwise NOT of packed double-precision (64-bit) floating-point elements in a and then AND with b, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tdst[i+63:i] := ((NOT a[i+63:i]) AND b[i+63:i])\nENDFOR")
VE_STR1(Desc_mm_andnot_ps, "Compute the bitwise NOT of packed single-precision (32-bit) floating-point elements in a and then AND with b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := ((NOT a[i+31:i]) AND b[i+31:i])\nENDFOR")
VE_STR1(Desc_mm_andnot_si128, "Compute the bitwise NOT of 128 bits (representing integer data) in a and then AND with b, and store the result in dst.\n\ndst[127:0] := ((NOT a[127:0]) AND b[127:0])")
VE_STR1(Desc_mm_avg_epu16, "Average packed unsigned 16-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tdst[i+15:i] := (a[i+15:i] + b[i+15:i] + 1) >> 1\nENDFOR")
VE_STR1(Desc_mm_avg_epu8, "Average packed unsigned 8-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tdst[i+7:i] := (a[i+7:i] + b[i+7:i] + 1) >> 1\nENDFOR")
VE_STR1(Desc_mm_avg_pu16, "Average packed unsigned 16-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*16\n\tdst[i+15:i] := (a[i+15:i] + b[i+15:i] + 1) >> 1\nENDFOR")
VE_STR1(Desc_mm_avg_pu8, "Average packed unsigned 8-bit integers in a and b, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*8\n\tdst[i+7:i] := (a[i+7:i] + b[i+7:i] + 1) >> 1\nENDFOR")
VE_STR1(Desc_mm_blend_epi16, "Blend packed 16-bit integers from a and b using control mask imm8, and store the results in dst.\n\nFOR j := 0 to 7\n\ti := j*16\n\tIF imm8[j]\n\t\tdst[i+15:i] := b[i+15:i]\n\tELSE\n\t\tdst[i+15:i] := a[i+15:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_blend_pd, "Blend packed double-precision (64-bit) floating-point elements from a and b using control mask imm8, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tIF imm8[j]\n\t\tdst[i+63:i] := b[i+63:i]\n\tELSE\n\t\tdst[i+63:i] := a[i+63:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_blend_ps, "Blend packed single-precision (32-bit) floating-point elements from a and b using control mask imm8, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tIF imm8[j]\n\t\tdst[i+31:i] := b[i+31:i]\n\tELSE\n\t\tdst[i+31:i] := a[i+31:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_blendv_epi8, "Blend packed 8-bit integers from a and b using mask, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*8\n\tIF mask[i+7]\n\t\tdst[i+7:i] := b[i+7:i]\n\tELSE\n\t\tdst[i+7:i] := a[i+7:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_blendv_pd, "Blend packed double-precision (64-bit) floating-point elements from a and b using mask, and store the results in dst.\n\nFOR j := 0 to 1\n\ti := j*64\n\tIF mask[i+63]\n\t\tdst[i+63:i] := b[i+63:i]\n\tELSE\n\t\tdst[i+63:i] := a[i+63:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_blendv_ps, "Blend packed single-precision (32-bit) floating-point elements from a and b using mask, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tIF mask[i+31]\n\t\tdst[i+31:i] := b[i+31:i]\n\tELSE\n\t\tdst[i+31:i] := a[i+31:i]\n\tFI\nENDFOR")
VE_STR1(Desc_mm_bslli_si128, "Shift a left by imm8 bytes while shifting in zeros, and store the results in dst.\n\ntmp := imm8[7:0]\nIF tmp > 15\n\ttmp := 16\nFI\ndst[127:0] := a[127:0] << (tmp*8)")
VE_STR1(Desc_mm_bsrli_si128, "Shift a right by imm8 bytes while shifting in zeros, and store the results in dst.\n\ntmp := imm8[7:0]\nIF tmp > 15\n\ttmp := 16\nFI\ndst[127:0] := a[127:0] >> (tmp*8)")
