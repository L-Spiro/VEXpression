VE_STR1(Desc_mm_madd_epi16, "Multiply packed signed 16-bit integers in a and b,\n producing intermediate signed 32-bit integers. Horizontally add \nadjacent pairs of intermediate 32-bit integers, and pack the results in dst.\n\nFOR j := 0 to 3\n\ti := j*32\n\tdst[i+31:i] := SignExtend32(a[i+31:i+16]*b[i+31:i+16]) + SignExtend32(a[i+15:i]*b[i+15:i])\nENDFOR")
