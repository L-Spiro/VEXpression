VE_STR1(Desc_mm256_and_pd, "Compute the bitwise AND of packed double-precision (64-bit) floating-point elements in a and b, and store the results in dst.\n\nFOR j := 0 to 3\n\ti := j*64\n\tdst[i+63:i] := (a[i+63:i] AND b[i+63:i])\nENDFOR\ndst[MAX:256] := 0")
