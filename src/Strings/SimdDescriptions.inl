VE_STR1(Desc_mm_dpbf16_ps, "Compute dot-product of BF16 (16-bit) floating-point pairs in a and b, accumulating the intermediate single-precision (32-bit) floating-point elements with elements in src, and store the results in dst.\n\nDEFINE make_fp32(x[15:0]) {\n\ty.fp32  := 0.0\n\ty[31:16] := x[15:0]\n\tRETURN y\n}\ndst := src\nFOR j := 0 to 3\n\tdst.fp32[j] += make_fp32(a.bf16[2*j+1]) * make_fp32(b.bf16[2*j+1])\n\tdst.fp32[j] += make_fp32(a.bf16[2*j+0]) * make_fp32(b.bf16[2*j+0])\nENDFOR\ndst[MAX:128] := 0")
