VE_STR1(Desc_mm_clog_ps, "Compute the natural logarithm of packed complex numbers in a, and store the complex results in dst.\n Each complex number is composed of two adjacent single-precision \n(32-bit) floating-point elements, which defines the complex number complex = vec.fp32[0] + i * vec.fp32[1].\n\nDEFINE CLOG(a[31:0], b[31:0]) {\n\tresult[31:0]  := LOG(SQRT(POW(a, 2.0) + POW(b, 2.0)))\n\tresult[63:32] := ATAN2(b, a)\n\tRETURN result\n}\nFOR j := 0 to 1\n\ti := j*64\n\tdst[i+63:i] := CLOG(a[i+31:i], a[i+63:i+32])\nENDFOR\ndst[MAX:128] := 0")
