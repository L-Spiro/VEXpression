VE_STR1(Desc_mm512_mask_scalef_round_pd, "Scale the packed double-precision (64-bit) floating-point elements in a using values from b, and store the results in dst using writemask k (elements are copied from src when the corresponding mask bit is not set).\n\tRounding is done according to the rounding[3:0] parameter, which can be one of:    (_MM_FROUND_TO_NEAREST_INT |_MM_FROUND_NO_EXC) // round to nearest, and suppress exceptions\n    (_MM_FROUND_TO_NEG_INF |_MM_FROUND_NO_EXC)     // round down, and suppress exceptions\n    (_MM_FROUND_TO_POS_INF |_MM_FROUND_NO_EXC)     // round up, and suppress exceptions\n    (_MM_FROUND_TO_ZERO |_MM_FROUND_NO_EXC)        // truncate, and suppress exceptions\n    _MM_FROUND_CUR_DIRECTION                       // use MXCSR.RC; see _MM_SET_ROUNDING_MODE\n\nDEFINE SCALE(src1, src2) {\n\tIF (src2 == NaN)\n\t\tIF (src2 == SNaN)\n\t\t\tRETURN QNAN(src2)\n\t\tFI\n\tELSE IF (src1 == NaN)\n\t\tIF (src1 == SNaN)\n\t\t\tRETURN QNAN(src1)\n\t\tFI\n\t\tIF (src2 != INF)\n\t\t\tRETURN QNAN(src1)\n\t\tFI\n\tELSE\n\t\ttmp_src2 := src2\n\t\ttmp_src1 := src1\n\t\tIF (IS_DENORMAL(src2) AND MXCSR.DAZ)\n\t\t\ttmp_src2 := 0\n\t\tFI\n\t\tIF (IS_DENORMAL(src1) AND MXCSR.DAZ)\n\t\t\ttmp_src1 := 0\n\t\tFI\n\tFI\n\tdst[63:0] := tmp_src1[63:0] * POW(2.0, FLOOR(tmp_src2[63:0]))\n\tRETURN dst[63:0]\n}\nFOR j := 0 to 7\n\ti := j*64\n\tIF k[j]\n\t\tdst[i+63:i] := SCALE(a[i+63:0], b[i+63:i])\n\tELSE\n\t\tdst[i+63:i] := src[i+63:i]\n\tFI\nENDFOR\ndst[MAX:512] := 0")
