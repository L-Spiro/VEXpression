VE_STR1(Desc_mm_loadh_pd, "Load a double-precision (64-bit) floating-point element from memory into the upper element of dst, and copy the lower element from a to dst. mem_addr does not need to be aligned on any particular boundary.\n\ndst[63:0] := a[63:0]\ndst[127:64] := MEM[mem_addr+63:mem_addr]")
