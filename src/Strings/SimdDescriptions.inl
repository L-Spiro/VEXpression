VE_STR1(Desc_mm512_cvtpslo_pd, "Performs element-by-element conversion of the lower half of packed single-precision (32-bit) floating-point elements in v2 to packed double-precision (64-bit) floating-point elements, storing the results in dst.\n\nFOR j := 0 to 7\n\ti := j*32\n\tn := j*64\n\tdst[n+63:n] := Convert_FP32_To_FP64(v2[i+31:i])\nENDFOR\ndst[MAX:512] := 0")
