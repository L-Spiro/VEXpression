VE_STR1(Desc_mm_mask_reduce_add_epi16, "Reduce the packed 16-bit integers in a by addition using mask k. Returns the sum of all active elements in a.\n\nDEFINE REDUCE_ADD(src, len) {\n\tIF len == 2\n\t\tRETURN src[15:0] + src[31:16]\n\tFI\n\tlen := len / 2\n\tFOR j:= 0 to (len-1)\n\t\ti := j*16\n\t\tsrc[i+15:i] := src[i+15:i] + src[i+16*len+15:i+16*len]\n\tENDFOR\n\tRETURN REDUCE_ADD(src[16*len-1:0], len)\n}\ntmp := a\nFOR j := 0 to 7\n\ti := j*16\n\tIF k[j]\n\t\ttmp[i+15:i] := a[i+15:i]\n\tELSE\n\t\ttmp[i+15:i] := 0\n\tFI\nENDFOR\ndst[15:0] := REDUCE_ADD(tmp, 8)")
