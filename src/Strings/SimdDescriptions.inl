VE_STR1(Desc_mm_mask_scalef_ps, "Scale the packed single-precision (32-bit) floating-point elements in a using values from b, and store the results in dst using writemask k (elements are copied from src when the corresponding mask bit is not set).\n\nDEFINE SCALE(src1, src2) {\n\tIF (src2 == NaN)\n\t\tIF (src2 == SNaN)\n\t\t\tRETURN QNAN(src2)\n\t\tFI\n\tELSE IF (src1 == NaN)\n\t\tIF (src1 == SNaN)\n\t\t\tRETURN QNAN(src1)\n\t\tFI\n\t\tIF (src2 != INF)\n\t\t\tRETURN QNAN(src1)\n\t\tFI\n\tELSE\n\t\ttmp_src2 := src2\n\t\ttmp_src1 := src1\n\t\tIF (IS_DENORMAL(src2) AND MXCSR.DAZ)\n\t\t\ttmp_src2 := 0\n\t\tFI\n\t\tIF (IS_DENORMAL(src1) AND MXCSR.DAZ)\n\t\t\ttmp_src1 := 0\n\t\tFI\n\tFI\n\tdst[31:0] := tmp_src1[31:0] * POW(2.0, FLOOR(tmp_src2[31:0]))\n\tRETURN dst[31:0]\n}\nFOR j := 0 to 3\n\ti := j*32\n\tIF k[j]\n\t\tdst[i+31:i] := SCALE(a[i+31:0], b[i+31:i])\n\tELSE\n\t\tdst[i+31:i] := src[i+31:i]\n\tFI\nENDFOR\ndst[MAX:128] := 0")
