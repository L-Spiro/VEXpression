VE_STR1(Desc_mm_mask_rol_epi32, "Rotate the bits in each packed 32-bit integer in a to the left by the number of bits specified in imm8, and store the results in dst using writemask k (elements are copied from src when the corresponding mask bit is not set).\n\nDEFINE LEFT_ROTATE_DWORDS(src, count_src) {\n\tcount := count_src % 32\n\tRETURN (src << count) OR (src >> (32 - count))\n}\nFOR j := 0 to 3\n\ti := j*32\n\tIF k[j]\n\t\tdst[i+31:i] := LEFT_ROTATE_DWORDS(a[i+31:i], imm8[7:0])\n\tELSE\n\t\tdst[i+31:i] := src[i+31:i]\n\tFI\nENDFOR\ndst[MAX:128] := 0")
