VE_STR1(Desc_axor_i64, "Atomically xor a 64-bit value at memory operand __A and a 64-bit __B, and store the result to the same memory location.\n\nMEM[__A+63:__A] := MEM[__A+63:__A] XOR __B[63:0]")
VE_STR1(Desc_bextr_u32, "Extract contiguous bits from unsigned 32-bit integer a, and store the result in dst. Extract the number of bits specified by len, starting at the bit specified by start.\n\ntmp[511:0] := a\ndst[31:0] := ZeroExtend32(tmp[(start[7:0] + len[7:0] - 1):start[7:0]])")
VE_STR1(Desc_bextr_u64, "Extract contiguous bits from unsigned 64-bit integer a, and store the result in dst. Extract the number of bits specified by len, starting at the bit specified by start.\n\ntmp[511:0] := a\ndst[63:0] := ZeroExtend64(tmp[(start[7:0] + len[7:0] - 1):start[7:0]])")
VE_STR1(Desc_bextr2_u32, "Extract contiguous bits from unsigned 32-bit integer a, and store the result in dst. Extract the number of bits specified by bits 15:8 of control, starting at the bit specified by bits 0:7 of control.\n\nstart := control[7:0]\nlen := control[15:8]\ntmp[511:0] := a\ndst[31:0] := ZeroExtend32(tmp[(start[7:0] + len[7:0] - 1):start[7:0]])")
VE_STR1(Desc_bextr2_u64, "Extract contiguous bits from unsigned 64-bit integer a, and store the result in dst. Extract the number of bits specified by bits 15:8 of control, starting at the bit specified by bits 0:7 of control..\n\nstart := control[7:0]\nlen := control[15:8]\ntmp[511:0] := a\ndst[63:0] := ZeroExtend64(tmp[(start[7:0] + len[7:0] - 1):start[7:0]])")
VE_STR1(Desc_bit_scan_forward, "Set dst to the index of the lowest set bit in 32-bit integer a. If no bits are set in a then dst is undefined.\n\ntmp := 0\nIF a == 0\n\t// dst is undefined\nELSE\n\tDO WHILE ((tmp < 32) AND a[tmp] == 0)\n\t\ttmp := tmp + 1\n\tOD\nFI\ndst := tmp")
VE_STR1(Desc_bit_scan_reverse, "Set dst to the index of the highest set bit in 32-bit integer a. If no bits are set in a then dst is undefined.\n\ntmp := 31\nIF a == 0\n\t// dst is undefined\nELSE\n\tDO WHILE ((tmp > 0) AND a[tmp] == 0)\n\t\ttmp := tmp - 1\n\tOD\nFI\ndst := tmp")
VE_STR1(Desc_BitScanForward, "Set index to the index of the lowest set bit in 32-bit integer mask. If no bits are set in a, then index is undefined and dst is set to 0, otherwise dst is set to 1.\n\ntmp := 0\nIF a == 0\n\t// MEM[index+31:index] is undefined\n\tdst := 0\nELSE\n\tDO WHILE ((tmp < 32) AND a[tmp] == 0)\n\t\ttmp := tmp + 1\n\tOD\n\tMEM[index+31:index] := tmp\n\tdst := (tmp == 31) ? 0 : 1\nFI")
VE_STR1(Desc_BitScanForward64, "Set index to the index of the lowest set bit in 32-bit integer mask. If no bits are set in a, then index is undefined and dst is set to 0, otherwise dst is set to 1.\n\ntmp := 0\nIF a == 0\n\t// MEM[index+31:index] is undefined\n\tdst := 0\nELSE\n\tDO WHILE ((tmp < 64) AND a[tmp] == 0)\n\t\ttmp := tmp + 1\n\tOD\n\tMEM[index+31:index] := tmp\n\tdst := (tmp == 63) ? 0 : 1\nFI")
VE_STR1(Desc_BitScanReverse, "Set index to the index of the highest set bit in 32-bit integer mask. If no bits are set in a, then index is undefined and dst is set to 0, otherwise dst is set to 1.\n\ntmp := 31\nIF a == 0\n\t// MEM[index+31:index] is undefined\n\tdst := 0\nELSE\n\tDO WHILE ((tmp > 0) AND a[tmp] == 0)\n\t\ttmp := tmp - 1\n\tOD\n\tMEM[index+31:index] := tmp\n\tdst := (tmp == 0) ? 0 : 1\nFI")
VE_STR1(Desc_BitScanReverse64, "Set index to the index of the highest set bit in 32-bit integer mask. If no bits are set in a, then index is undefined and dst is set to 0, otherwise dst is set to 1.\n\ntmp := 63\nIF a == 0\n\t// MEM[index+31:index] is undefined\n\tdst := 0\nELSE\n\tDO WHILE ((tmp > 0) AND a[tmp] == 0)\n\t\ttmp := tmp - 1\n\tOD\n\tMEM[index+31:index] := tmp\n\tdst := (tmp == 0) ? 0 : 1\nFI")
VE_STR1(Desc_bittest, "Return the bit at index b of 32-bit integer a.\n\naddr := a + ZeroExtend64(b)\ndst[0] := MEM[addr]")
VE_STR1(Desc_bittest64, "Return the bit at index b of 64-bit integer a.\n\naddr := a + b\ndst[0] := MEM[addr]")
VE_STR1(Desc_bittestandcomplement, "Return the bit at index b of 32-bit integer a, and set that bit to its complement.\n\naddr := a + ZeroExtend64(b)\ndst[0] := MEM[addr]\nMEM[addr] := ~dst[0]")
VE_STR1(Desc_bittestandcomplement64, "Return the bit at index b of 64-bit integer a, and set that bit to its complement.\n\naddr := a + b\ndst[0] := MEM[addr]\nMEM[addr] := ~dst[0]")
VE_STR1(Desc_bittestandreset, "Return the bit at index b of 32-bit integer a, and set that bit to zero.\n\naddr := a + ZeroExtend64(b)\ndst[0] := MEM[addr]\nMEM[addr] := 0")
VE_STR1(Desc_bittestandreset64, "Return the bit at index b of 64-bit integer a, and set that bit to zero.\n\naddr := a + b\ndst[0] := MEM[addr]\nMEM[addr] := 0")
VE_STR1(Desc_bittestandset, "Return the bit at index b of 32-bit integer a, and set that bit to one.\n\naddr := a + ZeroExtend64(b)\ndst[0] := MEM[addr]\nMEM[addr] := 1")
VE_STR1(Desc_bittestandset64, "Return the bit at index b of 64-bit integer a, and set that bit to one.\n\naddr := a + b\ndst[0] := MEM[addr]\nMEM[addr] := 1")
VE_STR1(Desc_blsi_u32, "Extract the lowest set bit from unsigned 32-bit integer a and set the corresponding bit in dst. All other bits in dst are zeroed, and all bits are zeroed if no bits are set in a.\n\ndst := (-a) AND a")
VE_STR1(Desc_blsi_u64, "Extract the lowest set bit from unsigned 64-bit integer a and set the corresponding bit in dst. All other bits in dst are zeroed, and all bits are zeroed if no bits are set in a.\n\ndst := (-a) AND a")
VE_STR1(Desc_blsmsk_u32, "Set all the lower bits of dst up to and including the lowest set bit in unsigned 32-bit integer a.\n\ndst := (a - 1) XOR a")
VE_STR1(Desc_blsmsk_u64, "Set all the lower bits of dst up to and including the lowest set bit in unsigned 64-bit integer a.\n\ndst := (a - 1) XOR a")
VE_STR1(Desc_blsr_u32, "Copy all bits from unsigned 32-bit integer a to dst, and reset (set to 0) the bit in dst that corresponds to the lowest set bit in a.\n\ndst := (a - 1) AND a")
VE_STR1(Desc_blsr_u64, "Copy all bits from unsigned 64-bit integer a to dst, and reset (set to 0) the bit in dst that corresponds to the lowest set bit in a.\n\ndst := (a - 1) AND a")
VE_STR1(Desc_bnd_chk_ptr_bounds, "Checks if [q, q + size - 1] is within the lower and upper bounds of q and throws a #BR if not.\n\nIF (q + size - 1) < q.LB OR (q + size - 1) > q.UB\n\t#BR\nFI")
VE_STR1(Desc_bnd_chk_ptr_lbounds, "Checks if q is within its lower bound, and throws a #BR if not.\n\nIF q < q.LB\n\t#BR\nFI")
VE_STR1(Desc_bnd_chk_ptr_ubounds, "Checks if q is within its upper bound, and throws a #BR if not.\n\nIF q > q.UB\n\t#BR\nFI")
VE_STR1(Desc_bnd_copy_ptr_bounds, "Make a pointer with the value of q and bounds set to the bounds of r (e.g. copy the bounds of r to pointer q), and store the result in dst.\n\ndst := q\ndst.LB := r.LB\ndst.UB := r.UB")
VE_STR1(Desc_bnd_get_ptr_lbound, "Return the lower bound of q.\n\ndst := q.LB")
VE_STR1(Desc_bnd_get_ptr_ubound, "Return the upper bound of q.\n\ndst := q.UB")
VE_STR1(Desc_bnd_init_ptr_bounds, "Make a pointer with the value of q and open bounds, which allow the pointer to access the entire virtual address space, and store the result in dst.\n\ndst := q\ndst.LB := 0\ndst.UB := 0")
VE_STR1(Desc_bnd_narrow_ptr_bounds, "Narrow the bounds for pointer q to the intersection of the bounds of r and the bounds [q, q + size - 1], and store the result in dst.\n\ndst := q\nIF r.LB > (q + size - 1) OR r.UB < q\n\tdst.LB := 1\n\tdst.UB := 0\nELSE\n\tdst.LB := MAX(r.LB, q)\n\tdst.UB := MIN(r.UB, (q + size - 1))\nFI")
VE_STR1(Desc_bnd_set_ptr_bounds, "Make a pointer with the value of srcmem and bounds set to [srcmem, srcmem + size - 1], and store the result in dst.\n\ndst := srcmem\ndst.LB := srcmem.LB\ndst.UB := srcmem + size - 1")
VE_STR1(Desc_bnd_store_ptr_bounds, "Stores the bounds of ptr_val pointer in memory at address ptr_addr.\n\nMEM[ptr_addr].LB := ptr_val.LB\nMEM[ptr_addr].UB := ptr_val.UB")
VE_STR1(Desc_bswap, "Reverse the byte order of 32-bit integer a, and store the result in dst. This intrinsic is provided for conversion between little and big endian values.\n\ndst[7:0] := a[31:24]\ndst[15:8] := a[23:16]\ndst[23:16] := a[15:8]\ndst[31:24] := a[7:0]")
VE_STR1(Desc_bswap64, "Reverse the byte order of 64-bit integer a, and store the result in dst. This intrinsic is provided for conversion between little and big endian values.\n\ndst[7:0] := a[63:56]\ndst[15:8] := a[55:48]\ndst[23:16] := a[47:40]\ndst[31:24] := a[39:32]\ndst[39:32] := a[31:24]\ndst[47:40] := a[23:16]\ndst[55:48] := a[15:8]\ndst[63:56] := a[7:0]")
VE_STR1(Desc_bzhi_u32, "Copy all bits from unsigned 32-bit integer a to dst, and reset (set to 0) the high bits in dst starting at index.\n\nn := index[7:0]\ndst := a\nIF (n < 32)\n\tdst[31:n] := 0\nFI")
VE_STR1(Desc_bzhi_u64, "Copy all bits from unsigned 64-bit integer a to dst, and reset (set to 0) the high bits in dst starting at index.\n\nn := index[7:0]\ndst := a\nIF (n < 64)\n\tdst[63:n] := 0\nFI")
VE_STR1(Desc_castf32_u32, "Cast from type float to type unsigned __int32 without conversion.\n\tThis intrinsic is only used for compilation and does not generate any instructions, thus it has zero latency.")
VE_STR1(Desc_castf64_u64, "Cast from type double to type unsigned __int64 without conversion.\n\tThis intrinsic is only used for compilation and does not generate any instructions, thus it has zero latency.")
VE_STR1(Desc_castu32_f32, "Cast from type unsigned __int32 to type float without conversion.\n\tThis intrinsic is only used for compilation and does not generate any instructions, thus it has zero latency.")
VE_STR1(Desc_castu64_f64, "Cast from type unsigned __int64 to type double without conversion.\n\tThis intrinsic is only used for compilation and does not generate any instructions, thus it has zero latency.")
VE_STR1(Desc_mm_cldemote, "Hint to hardware that the cache line that contains p should be demoted from the cache closest to the processor core to a level more distant from the processor core.")
VE_STR1(Desc_mm_clflushopt, "Invalidate and flush the cache line that contains p from all levels of the cache hierarchy.")
VE_STR1(Desc_mm256_clmulepi64_epi128, "Carry-less multiplication of one quadword of\n\t\t'b' by one quadword of 'c', stores\n\t\tthe 128-bit result in 'dst'. The immediate 'Imm8' is\n\t\tused to determine which quadwords of 'b'\n\t\tand 'c' should be used.\n\nDEFINE PCLMUL128(X,Y) {\n\tFOR i := 0 to 63\n\t\tTMP[i] := X[ 0 ] and Y[ i ]\n\t\tFOR j := 1 to i\n\t\t\tTMP[i] := TMP[i] xor (X[ j ] and Y[ i - j ])\n\t\tENDFOR\n\t\tDEST[ i ] := TMP[ i ]\n\tENDFOR\n\tFOR i := 64 to 126\n\t\tTMP[i] := 0\n\t\tFOR j := i - 63 to 63\n\t\t\tTMP[i] := TMP[i] xor (X[ j ] and Y[ i - j ])\n\t\tENDFOR\n\t\tDEST[ i ] := TMP[ i ]\n\tENDFOR\n\tDEST[127] := 0\n\tRETURN DEST // 128b vector\n}\nFOR i := 0 to 1\n\tIF Imm8[0] == 0\n\t\tTEMP1 := b.m128[i].qword[0]\n\tELSE\n\t\tTEMP1 := b.m128[i].qword[1]\n\tFI\n\tIF Imm8[4] == 0\n\t\tTEMP2 := c.m128[i].qword[0]\n\tELSE\n\t\tTEMP2 := c.m128[i].qword[1]\n\tFI\n\tdst.m128[i] := PCLMUL128(TEMP1, TEMP2)\nENDFOR\ndst[MAX:256] := 0")
VE_STR1(Desc_mm512_clmulepi64_epi128, "Carry-less multiplication of one quadword of\n\t\t'b' by one quadword of 'c', stores\n\t\tthe 128-bit result in 'dst'. The immediate 'Imm8' is\n\t\tused to determine which quadwords of 'b'\n\t\tand 'c' should be used.\n\nDEFINE PCLMUL128(X,Y) {\n\tFOR i := 0 to 63\n\t\tTMP[i] := X[ 0 ] and Y[ i ]\n\t\tFOR j := 1 to i\n\t\t\tTMP[i] := TMP[i] xor (X[ j ] and Y[ i - j ])\n\t\tENDFOR\n\t\tDEST[ i ] := TMP[ i ]\n\tENDFOR\n\tFOR i := 64 to 126\n\t\tTMP[i] := 0\n\t\tFOR j := i - 63 to 63\n\t\t\tTMP[i] := TMP[i] xor (X[ j ] and Y[ i - j ])\n\t\tENDFOR\n\t\tDEST[ i ] := TMP[ i ]\n\tENDFOR\n\tDEST[127] := 0\n\tRETURN DEST // 128b vector\n}\nFOR i := 0 to 3\n\tIF Imm8[0] == 0\n\t\tTEMP1 := b.m128[i].qword[0]\n\tELSE\n\t\tTEMP1 := b.m128[i].qword[1]\n\tFI\n\tIF Imm8[4] == 0\n\t\tTEMP2 := c.m128[i].qword[0]\n\tELSE\n\t\tTEMP2 := c.m128[i].qword[1]\n\tFI\n\tdst.m128[i] := PCLMUL128(TEMP1, TEMP2)\nENDFOR\ndst[MAX:512] := 0")
VE_STR1(Desc_mm_clmulepi64_si128, "Perform a carry-less multiplication of two 64-bit integers, selected from a and b according to imm8, and store the results in dst.\n\nIF (imm8[0] == 0)\n\tTEMP1 := a[63:0]\nELSE\n\tTEMP1 := a[127:64]\nFI \nIF (imm8[4] == 0)\n\tTEMP2 := b[63:0]\nELSE \n\tTEMP2 := b[127:64]\nFI\nFOR i := 0 to 63\n\tTEMP[i] := (TEMP1[0] and TEMP2[i])\n\tFOR j := 1 to i\n\t\tTEMP[i] := TEMP[i] XOR (TEMP1[j] AND TEMP2[i-j])\n\tENDFOR \n\tdst[i] := TEMP[i]\nENDFOR\nFOR i := 64 to 127\n\tTEMP[i] := 0\n\tFOR j := (i - 63) to 63\n\t\tTEMP[i] := TEMP[i] XOR (TEMP1[j] AND TEMP2[i-j])\n\tENDFOR\n\tdst[i] := TEMP[i]\nENDFOR\ndst[127] := 0")
VE_STR1(Desc_clrssbsy, "Mark shadow stack pointed to by p as not busy.")
VE_STR1(Desc_clui, "Clear the user interrupt flag (UIF).")
VE_STR1(Desc_mm_clwb, "Write back to memory the cache line that contains p from any level of the cache hierarchy in the cache coherence domain.")
VE_STR1(Desc_cmpccxadd_epi32, "Compares the value from the memory __A with the value of __B. If the specified condition __D is met, then add the third operand __C to the __A and write it into __A, else the value of __A is unchanged. The return value is the original value of __A.\n\nCASE (__D[3:0]) OF\n0: OP := _CMPCCX_O\n1: OP := _CMPCCX_NO\n2: OP := _CMPCCX_B\n3: OP := _CMPCCX_NB\n4: OP := _CMPCCX_Z\n5: OP := _CMPCCX_NZ\n6: OP := _CMPCCX_BE\n7: OP := _CMPCCX_NBE\n8: OP := _CMPCCX_S\n9: OP := _CMPCCX_NS\n10: OP := _CMPCCX_P\n11: OP := _CMPCCX_NP\n12: OP := _CMPCCX_L\n13: OP := _CMPCCX_NL\n14: OP := _CMPCCX_LE\n15: OP := _CMPCCX_NLE\nESAC\ntmp1 := LOAD_LOCK(__A)\ntmp2 := tmp1 + __C\nIF (tmp1[31:0] OP __B[31:0])\n\tSTORE_UNLOCK(__A, tmp2)\nELSE\n\tSTORE_UNLOCK(__A, tmp1)\nFI\ndst[31:0] := tmp1[31:0]")
VE_STR1(Desc_cmpccxadd_epi64, "Compares the value from the memory __A with the value of __B. If the specified condition __D is met, then add the third operand __C to the __A and write it into __A, else the value of __A is unchanged. The return value is the original value of __A.\n\nCASE (__D[3:0]) OF\n0: OP := _CMPCCX_O\n1: OP := _CMPCCX_NO\n2: OP := _CMPCCX_B\n3: OP := _CMPCCX_NB\n4: OP := _CMPCCX_Z\n5: OP := _CMPCCX_NZ\n6: OP := _CMPCCX_BE\n7: OP := _CMPCCX_NBE\n8: OP := _CMPCCX_S\n9: OP := _CMPCCX_NS\n10: OP := _CMPCCX_P\n11: OP := _CMPCCX_NP\n12: OP := _CMPCCX_L\n13: OP := _CMPCCX_NL\n14: OP := _CMPCCX_LE\n15: OP := _CMPCCX_NLE\nESAC\ntmp1 := LOAD_LOCK(__A)\ntmp2 := tmp1 + __C\nIF (tmp1[63:0] OP __B[63:0])\n\tSTORE_UNLOCK(__A, tmp2)\nELSE\n\tSTORE_UNLOCK(__A, tmp1)\nFI\ndst[63:0] := tmp1[63:0]")
VE_STR1(Desc_mm_crc32_u16, "Starting with the initial value in crc, accumulates a CRC32 value for unsigned 16-bit integer v, and stores the result in dst.\n\ntmp1[15:0] := v[0:15] // bit reflection\ntmp2[31:0] := crc[0:31] // bit reflection\ntmp3[47:0] := tmp1[15:0] << 32\ntmp4[47:0] := tmp2[31:0] << 16\ntmp5[47:0] := tmp3[47:0] XOR tmp4[47:0]\ntmp6[31:0] := MOD2(tmp5[47:0], 0x11EDC6F41) // remainder from polynomial division modulus 2\ndst[31:0] := tmp6[0:31] // bit reflection")
VE_STR1(Desc_mm_crc32_u32, "Starting with the initial value in crc, accumulates a CRC32 value for unsigned 32-bit integer v, and stores the result in dst.\n\ntmp1[31:0] := v[0:31] // bit reflection\ntmp2[31:0] := crc[0:31] // bit reflection\ntmp3[63:0] := tmp1[31:0] << 32\ntmp4[63:0] := tmp2[31:0] << 32\ntmp5[63:0] := tmp3[63:0] XOR tmp4[63:0]\ntmp6[31:0] := MOD2(tmp5[63:0], 0x11EDC6F41) // remainder from polynomial division modulus 2\ndst[31:0] := tmp6[0:31] // bit reflection")
VE_STR1(Desc_mm_crc32_u64, "Starting with the initial value in crc, accumulates a CRC32 value for unsigned 64-bit integer v, and stores the result in dst.\n\ntmp1[63:0] := v[0:63] // bit reflection\ntmp2[31:0] := crc[0:31] // bit reflection\ntmp3[95:0] := tmp1[31:0] << 32\ntmp4[95:0] := tmp2[63:0] << 64\ntmp5[95:0] := tmp3[95:0] XOR tmp4[95:0]\ntmp6[31:0] := MOD2(tmp5[95:0], 0x11EDC6F41) // remainder from polynomial division modulus 2\ndst[31:0] := tmp6[0:31] // bit reflection")
VE_STR1(Desc_mm_crc32_u8, "Starting with the initial value in crc, accumulates a CRC32 value for unsigned 8-bit integer v, and stores the result in dst.\n\ntmp1[7:0] := v[0:7] // bit reflection\ntmp2[31:0] := crc[0:31] // bit reflection\ntmp3[39:0] := tmp1[7:0] << 32 \ntmp4[39:0] := tmp2[31:0] << 8\ntmp5[39:0] := tmp3[39:0] XOR tmp4[39:0]\ntmp6[31:0] := MOD2(tmp5[39:0], 0x11EDC6F41) // remainder from polynomial division modulus 2\ndst[31:0] := tmp6[0:31] // bit reflection")
VE_STR1(Desc_cvtsh_ss, "Convert the half-precision (16-bit) floating-point value a to a single-precision (32-bit) floating-point value, and store the result in dst.\n\ndst[31:0] := Convert_FP16_To_FP32(a[15:0])")
VE_STR1(Desc_cvtss_sh, "Convert the single-precision (32-bit) floating-point value a to a half-precision (16-bit) floating-point value, and store the result in dst.\n\tRounding is done according to the rounding[3:0] parameter, which can be one of:    (_MM_FROUND_TO_NEAREST_INT |_MM_FROUND_NO_EXC) // round to nearest, and suppress exceptions\n    (_MM_FROUND_TO_NEG_INF |_MM_FROUND_NO_EXC)     // round down, and suppress exceptions\n    (_MM_FROUND_TO_POS_INF |_MM_FROUND_NO_EXC)     // round up, and suppress exceptions\n    (_MM_FROUND_TO_ZERO |_MM_FROUND_NO_EXC)        // truncate, and suppress exceptions\n    _MM_FROUND_CUR_DIRECTION                       // use MXCSR.RC; see _MM_SET_ROUNDING_MODE\n\ndst[15:0] := Convert_FP32_To_FP16(a[31:0])")
VE_STR1(Desc_directstoreu_u32, "Store 32-bit integer from val into memory using direct store.\n\nMEM[dst+31:dst] := val[31:0]")
VE_STR1(Desc_directstoreu_u64, "Store 64-bit integer from val into memory using direct store.\n\nMEM[dst+63:dst] := val[63:0]")
VE_STR1(Desc_encls_u32, "Invoke the Intel SGX enclave system (privileged) leaf function specified by a, and return the error code. The __data\n array contains 3 32- or 64-bit elements that may act as input, output, \nor be unused, depending on the semantics of the specified leaf function;\n these correspond to ebx, ecx, and edx.")
VE_STR1(Desc_enclu_u32, "Invoke the Intel SGX enclave user (non-privilege) leaf function specified by a, and return the error code. The __data\n array contains 3 32- or 64-bit elements that may act as input, output, \nor be unused, depending on the semantics of the specified leaf function;\n these correspond to ebx, ecx, and edx.")
VE_STR1(Desc_enclv_u32, "Invoke the Intel SGX enclave virtualized (VMM) leaf function specified by a, and return the error code. The __data\n array contains 3 32- or 64-bit elements that may act as input, output, \nor be unused, depending on the semantics of the specified leaf function;\n these correspond to ebx, ecx, and edx.")
VE_STR1(Desc_mm_encodekey128_u32, "Wrap a 128-bit AES key from __key into a 384-bit key __h stored in __h and set IWKey's NoBackup and KeySource bits in dst. The explicit source operand __htype specifies __h restrictions.\n\n__h[383:0] := WrapKey128(__key[127:0], __htype)\ndst[0] := IWKey.NoBackup\ndst[4:1] := IWKey.KeySource[3:0]")
VE_STR1(Desc_mm_encodekey256_u32, "Wrap a 256-bit AES key from __key_hi and __key_lo into a 512-bit key stored in __h and set IWKey's NoBackup and KeySource bits in dst. The 32-bit __htype specifies __h restrictions.\n\n__h[511:0] := WrapKey256(__key_lo[127:0], __key_hi[127:0], __htype)\ndst[0] := IWKey.NoBackup\ndst[4:1] := IWKey.KeySource[3:0]")
VE_STR1(Desc_enqcmd, "Reads 64-byte command pointed by __src, formats 64-byte enqueue store data, and performs 64-byte enqueue store to memory pointed by __dst. This intrinsics may only be used in User mode.")
VE_STR1(Desc_enqcmds, "Reads 64-byte command pointed by __src, formats 64-byte enqueue store data, and performs 64-byte enqueue store to memory pointed by __dst This intrinsic may only be used in Privileged mode.")
VE_STR1(Desc_fxrstor, "Reload the x87 FPU, MMX technology, XMM, and MXCSR registers from the 512-byte memory image at mem_addr.\n This data should have been written to memory previously using the \nFXSAVE instruction, and in the same format as required by the operating \nmode. mem_addr must be aligned on a 16-byte boundary.\n\nstate_x87_fpu_mmx_sse := fxrstor(MEM[mem_addr+512*8:mem_addr])")
VE_STR1(Desc_fxrstor64, "Reload the x87 FPU, MMX technology, XMM, and MXCSR registers from the 512-byte memory image at mem_addr.\n This data should have been written to memory previously using the \nFXSAVE64 instruction, and in the same format as required by the \noperating mode. mem_addr must be aligned on a 16-byte boundary.\n\nstate_x87_fpu_mmx_sse := fxrstor64(MEM[mem_addr+512*8:mem_addr])")
VE_STR1(Desc_fxsave, "Save the current state of the x87 FPU, MMX technology, XMM, and MXCSR registers to a 512-byte memory location at mem_addr.\n The layout of the 512-byte region depends on the operating mode. Bytes \n[511:464] are available for software use and will not be overwritten by \nthe processor.\n\nMEM[mem_addr+512*8:mem_addr] := fxsave(state_x87_fpu_mmx_sse)")
VE_STR1(Desc_fxsave64, "Save the current state of the x87 FPU, MMX technology, XMM, and MXCSR registers to a 512-byte memory location at mem_addr.\n The layout of the 512-byte region depends on the operating mode. Bytes \n[511:464] are available for software use and will not be overwritten by \nthe processor.\n\nMEM[mem_addr+512*8:mem_addr] := fxsave64(state_x87_fpu_mmx_sse)")
VE_STR1(Desc_get_ssp, "If CET is enabled, read the low 32-bits of the current shadow stack pointer, and store the result in dst. Otherwise return 0.\n\ndst := SSP[31:0]")
VE_STR1(Desc_get_ssp_2, "If CET is enabled, read the current shadow stack pointer, and store the result in dst. Otherwise return 0.\n\ndst := SSP[63:0]")
VE_STR1(Desc_mm_gf2p8affine_epi64_epi8, "Compute an affine transformation in the Galois Field 2^8. An affine transformation is defined by A * x + b, where A represents an 8 by 8 bit matrix, x represents an 8-bit vector, and b is a constant immediate byte. Store the packed 8-bit results in dst.\n\nDEFINE parity(x) {\n\tt := 0\n\tFOR i := 0 to 7\n\t\tt := t XOR x.bit[i]\n\tENDFOR\n\tRETURN t\n}\nDEFINE affine_byte(tsrc2qw, src1byte, imm8) {\n\tFOR i := 0 to 7\n\t\tretbyte.bit[i] := parity(tsrc2qw.byte[7-i] AND src1byte) XOR imm8.bit[i]\n\tENDFOR\n\tRETURN retbyte\n}\nFOR j := 0 TO 1\n\tFOR i := 0 to 7\n\t\tdst.qword[j].byte[i] := affine_byte(A.qword[j], x.qword[j].byte[i], b)\n\tENDFOR\nENDFOR\ndst[MAX:128] := 0")
VE_STR1(Desc_mm_mask_gf2p8affine_epi64_epi8, "Compute an affine transformation in the Galois Field 2^8. An affine transformation is defined by A * x + b, where A represents an 8 by 8 bit matrix, x represents an 8-bit vector, and b is a constant immediate byte. Store the packed 8-bit results in dst using writemask k (elements are copied from src when the corresponding mask bit is not set).\n\nDEFINE parity(x) {\n\tt := 0\n\tFOR i := 0 to 7\n\t\tt := t XOR x.bit[i]\n\tENDFOR\n\tRETURN t\n}\nDEFINE affine_byte(tsrc2qw, src1byte, imm8) {\n\tFOR i := 0 to 7\n\t\tretbyte.bit[i] := parity(tsrc2qw.byte[7-i] AND src1byte) XOR imm8.bit[i]\n\tENDFOR\n\tRETURN retbyte\n}\nFOR j := 0 TO 1\n\tFOR i := 0 to 7\n\t\tIF k[j*8+i]\n\t\t\tdst.qword[j].byte[i] := affine_byte(A.qword[j], x.qword[j].byte[i], b)\n\t\tELSE\n\t\t\tdst.qword[j].byte[i] := src.qword[j].byte[i]\n\t\tFI\n\tENDFOR\nENDFOR\ndst[MAX:128] := 0")
VE_STR1(Desc_mm_maskz_gf2p8affine_epi64_epi8, "Compute an affine transformation in the Galois Field 2^8. An affine transformation is defined by A * x + b, where A represents an 8 by 8 bit matrix, x represents an 8-bit vector, and b is a constant immediate byte. Store the packed 8-bit results in dst using zeromask k (elements are zeroed out when the corresponding mask bit is not set).\n\nDEFINE parity(x) {\n\tt := 0\n\tFOR i := 0 to 7\n\t\tt := t XOR x.bit[i]\n\tENDFOR\n\tRETURN t\n}\nDEFINE affine_byte(tsrc2qw, src1byte, imm8) {\n\tFOR i := 0 to 7\n\t\tretbyte.bit[i] := parity(tsrc2qw.byte[7-i] AND src1byte) XOR imm8.bit[i]\n\tENDFOR\n\tRETURN retbyte\n}\nFOR j := 0 TO 1\n\tFOR i := 0 to 7\n\t\tIF k[j*8+i]\n\t\t\tdst.qword[j].byte[i] := affine_byte(A.qword[j], x.qword[j].byte[i], b)\n\t\tELSE\n\t\t\tdst.qword[j].byte[i] := 0\n\t\tFI\n\tENDFOR\nENDFOR\ndst[MAX:128] := 0")
