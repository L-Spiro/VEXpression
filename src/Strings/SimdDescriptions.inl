VE_STR1(Desc_mm256_blend_epi16, "Blend packed 16-bit integers from a and b within 128-bit lanes using control mask imm8, and store the results in dst.\n\nFOR j := 0 to 15\n\ti := j*16\n\tIF imm8[j%8]\n\t\tdst[i+15:i] := b[i+15:i]\n\tELSE\n\t\tdst[i+15:i] := a[i+15:i]\n\tFI\nENDFOR\ndst[MAX:256] := 0")
